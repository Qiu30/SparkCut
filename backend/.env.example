VIDEO_CUT_PIPELINE_MODE=mock
VIDEO_CUT_MAX_CONCURRENT_JOBS=1
VIDEO_CUT_RECOVER_JOBS=true

# OpenAI-compatible Chat Completions endpoint for v0.4 real AI analysis.
VIDEO_CUT_LLM_ENDPOINT=https://wishub-x6.ctyun.cn/coding/v1/chat/completions
VIDEO_CUT_LLM_API_KEY=<your-api-key>
VIDEO_CUT_LLM_MODEL=GLM-5.1
VIDEO_CUT_LLM_TIMEOUT_SECONDS=45

# Optional ASR command. The {input} placeholder is replaced with the source MP4 path.
VIDEO_CUT_WHISPER_COMMAND=uv run python scripts/run_whisper_base.py "{input}" --job-id {job_id} --seconds 12
VIDEO_CUT_ASR_TIMEOUT_SECONDS=300
VIDEO_CUT_FFMPEG_TIMEOUT_SECONDS=600
