# Copy this file to .env before production deployment.
# Never commit the real .env file.

# Web entrypoint exposed by the frontend nginx container.
VIDEO_CUT_WEB_PORT=8080

# Pipeline mode:
# - auto: run real capabilities when configured, degrade to mock when missing
# - real: require LLM, Whisper command, and ffmpeg; fail jobs if missing
# - mock: demo pipeline only
VIDEO_CUT_PIPELINE_MODE=auto

# OpenAI-compatible LLM URL. Plain host/path auto-appends /v1/chat/completions.
# End with / to skip auto /v1; end with # to force the exact URL.
VIDEO_CUT_LLM_ENDPOINT=https://wishub-x6.ctyun.cn/coding/v1
VIDEO_CUT_LLM_API_KEY=replace-with-your-key
VIDEO_CUT_LLM_MODEL=GLM-5.1
VIDEO_CUT_LLM_TIMEOUT_SECONDS=45

# Local Whisper command executed inside the backend container.
# The production image skips Whisper/PyTorch by default; set this to true before
# `docker compose up -d --build` if you want local Whisper bundled in the image.
VIDEO_CUT_BUILD_WITH_WHISPER=false
VIDEO_CUT_WHISPER_COMMAND=python scripts/run_whisper_base.py "{input}" --job-id {job_id} --material-id {material_id} --fingerprint {fingerprint} --model {model} --seconds {seconds} --language {language} --model-cache /app/model-cache/whisper --output-file "{output_file}"
VIDEO_CUT_DEFAULT_WHISPER_MODEL=base
VIDEO_CUT_ASR_CLIP_SECONDS=0
VIDEO_CUT_ASR_LANGUAGE=zh
VIDEO_CUT_ASR_TIMEOUT_SECONDS=1800
VIDEO_CUT_FFMPEG_TIMEOUT_SECONDS=600

# SQLite database and uploaded/generated media storage.
VIDEO_CUT_DB_URL=sqlite:////app/data/videocut.db
VIDEO_CUT_STORAGE_DIR=/app/storage

# Production limits.
VIDEO_CUT_MAX_CONCURRENT_JOBS=1
VIDEO_CUT_RECOVER_JOBS=true
VIDEO_CUT_MAX_VIDEO_BYTES=2147483648
VIDEO_CUT_MAX_WORKSPACE_MATERIALS=100
VIDEO_CUT_MAX_JOB_MATERIALS=100
